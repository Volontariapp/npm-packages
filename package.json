{
  "name": "@volontariapp/npm-packages",
  "version": "0.0.0",
  "private": true,
  "description": "Volontariapp shared npm packages monorepo",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -A --topological run build",
    "lint": "yarn workspaces foreach -A run lint",
    "lint:fix": "yarn workspaces foreach -A run lint:fix",
    "format": "prettier --write .",
    "test": "yarn workspaces foreach -A run test",
    "prepare": "husky",
    "create-package": "bash scripts/create-package.sh",
    "check-changelogs": "bash scripts/check-changelogs.sh",
    "release:ci": "bash scripts/ci-package-publish.sh"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "eslint": "9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3"
  }
}
