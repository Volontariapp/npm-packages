{
  "name": "@volontariapp/domain-event",
  "version": "2.4.3",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "Domain event definitions and contracts for Volontariapp",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules $(yarn bin jest)",
    "test:integration": "node --experimental-vm-modules $(yarn bin jest) --config jest.integration.config.js --runInBand",
    "test:all": "yarn test && yarn test:integration",
    "test:watch": "node --experimental-vm-modules $(yarn bin jest) --watch",
    "test:coverage": "node --experimental-vm-modules $(yarn bin jest) --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\"",
    "typeorm": "typeorm-ts-node-esm",
    "migration:run": "TYPEORM_MIGRATION_RUN=true yarn typeorm migration:run -d src/test/data-source.ts"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@nestjs/typeorm": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "jest": "^30.3.0",
    "pg": "^8.20.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.20",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@volontariapp/contracts": "workspace:*",
    "@volontariapp/database": "workspace:*",
    "@volontariapp/errors": "workspace:*",
    "@volontariapp/errors-nest": "workspace:*",
    "@volontariapp/logger": "workspace:*",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@nestjs/typeorm": "^11.0.1",
    "typeorm": "^0.3.20"
  }
}
