{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": "./",
    "paths": {
      "@volontariapp/bridge": ["../bridge/src/index.ts"],
      "@volontariapp/logger": ["../logger/src/index.ts"],
      "@volontariapp/errors": ["../errors/src/index.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["jest", "node"]
  },
  "include": ["src"]
}
