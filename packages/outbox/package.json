{
  "name": "@volontariapp/outbox",
  "version": "0.2.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "prepublishOnly": "yarn build",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules $(yarn bin jest)",
    "test:coverage": "node --experimental-vm-modules $(yarn bin jest) --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\"",
    "test:watch": "node --experimental-vm-modules $(yarn bin jest) --watch",
    "db:up": "docker-compose -f ../../docker-compose.test.yml up -d",
    "db:down": "docker-compose -f ../../docker-compose.test.yml down"
  },
  "dependencies": {
    "@volontariapp/database": "1.8.0-snap-8a230de",
    "@volontariapp/errors": "workspace:*",
    "@volontariapp/logger": "workspace:*"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "typescript": "5.7.3"
  }
}
