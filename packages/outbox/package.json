{
  "name": "@volontariapp/outbox",
  "version": "0.9.41",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/test/utils/index.d.ts",
      "import": "./dist/test/utils/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "prepublishOnly": "yarn build",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules $(yarn bin jest)",
    "test:coverage": "node --experimental-vm-modules $(yarn bin jest) --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\"",
    "test:watch": "node --experimental-vm-modules $(yarn bin jest) --watch",
    "db:up": "docker compose -f ../../ci-tools/testing/docker-compose.yml --profile test up -d redis",
    "db:down": "docker compose -f ../../ci-tools/testing/docker-compose.yml --profile test stop redis"
  },
  "dependencies": {
    "@volontariapp/config": "workspace:*",
    "@volontariapp/database": "workspace:*",
    "@volontariapp/errors": "workspace:*",
    "@volontariapp/logger": "workspace:*",
    "@volontariapp/messaging": "workspace:*",
    "@volontariapp/shared": "workspace:*",
    "@volontariapp/testing": "workspace:*",
    "bullmq": "^5.76.5",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8",
    "@volontariapp/testing": "workspace:*",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.7.3"
  }
}
