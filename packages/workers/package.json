{
  "name": "@volontariapp/workers",
  "version": "1.2.31",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "Abstract BullMQ worker base for Volontariapp NestJS workers",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "prepublishOnly": "yarn build",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules $(yarn bin jest)",
    "test:coverage": "INTEGRATION=all node --experimental-vm-modules $(yarn bin jest) --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\"",
    "test:watch": "node --experimental-vm-modules $(yarn bin jest) --watch",
    "test:int": "INTEGRATION=true node --experimental-vm-modules $(yarn bin jest)",
    "test:int:watch": "INTEGRATION=true node --experimental-vm-modules $(yarn bin jest) --watch",
    "db:up": "docker compose -f ../../ci-tools/testing/docker-compose.yml --profile test up -d test-db redis",
    "db:down": "docker compose -f ../../ci-tools/testing/docker-compose.yml --profile test stop test-db redis"
  },
  "dependencies": {
    "@volontariapp/bridge": "workspace:*",
    "@volontariapp/config": "workspace:*",
    "@volontariapp/database": "workspace:*",
    "@volontariapp/health-check": "workspace:*",
    "@volontariapp/logger": "workspace:*",
    "@volontariapp/messaging": "workspace:*",
    "@volontariapp/outbox": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bullmq": "^5.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@volontariapp/database": "workspace:*",
    "@volontariapp/outbox": "workspace:*",
    "@volontariapp/testing": "workspace:*",
    "bullmq": "^5.76.5",
    "ioredis": "^5.3.7",
    "jest": "^30.3.0",
    "pg": "^8.11.5",
    "ts-jest": "^29.4.6",
    "typeorm": "^0.3.28",
    "typescript": "5.7.3"
  }
}
