{
  "name": "@volontariapp/contracts",
  "version": "3.1.5",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "Pure TypeScript interfaces for Volontariapp gRPC contracts (Front-end compatible)",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "prepublishOnly": "yarn build",
    "build": "yarn fix-esm && tsc -p tsconfig.json",
    "fix-esm": "node scripts/fix-esm.mjs",
    "lint": "eslint src/",
    "dev:sync-proto": "rm -rf proto && ln -s ../../../proto-registry/proto ./proto",
    "test": "echo \"No tests yet\""
  },
  "devDependencies": {
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@volontariapp/logger": "workspace:*",
    "protobufjs": "7.5.3"
  }
}
