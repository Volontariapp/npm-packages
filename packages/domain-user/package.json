{
  "name": "@volontariapp/domain-user",
  "version": "2.8.2",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Volontariapp/npm-packages.git"
  },
  "description": "Domain user definitions and contracts for Volontariapp",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules ../../node_modules/.bin/jest",
    "test:integration": "node --experimental-vm-modules ../../node_modules/.bin/jest --config jest.integration.config.js --runInBand",
    "test:all": "yarn test && yarn test:integration",
    "test:watch": "node --experimental-vm-modules ../../node_modules/.bin/jest --watch",
    "test:coverage": "node --experimental-vm-modules ../../node_modules/.bin/jest --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\" --coverageReporters=\"json\"",
    "test:coverage:integration": "node --experimental-vm-modules ../../node_modules/.bin/jest --config jest.integration.config.js --coverage --coverageReporters=\"text\" --coverageReporters=\"json-summary\" --coverageReporters=\"lcov\" --coverageReporters=\"json\" --runInBand",
    "typeorm": "typeorm-ts-node-esm",
    "migration:run": "TYPEORM_MIGRATION_RUN=true yarn typeorm migration:run -d src/test/data-source.ts"
  },
  "dependencies": {
    "@volontariapp/auth": "workspace:*",
    "@volontariapp/contracts": "workspace:*",
    "@volontariapp/crypto": "workspace:*",
    "@volontariapp/database": "workspace:*",
    "@volontariapp/errors": "workspace:*",
    "@volontariapp/errors-nest": "0.12.0-snap-26e8dd4",
    "@volontariapp/logger": "workspace:*",
    "@volontariapp/messaging": "workspace:*",
    "@volontariapp/shared": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/typeorm": "^11.0.1",
    "@volontariapp/testing": "workspace:*",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "typeorm": "^0.3.28",
    "typescript": "5.7.3"
  }
}
